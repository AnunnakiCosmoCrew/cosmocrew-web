---
import { getMetrics } from '../lib/source';

/**
 * Dashboard tabs: overview + one per app, derived from the data source so the
 * nav can't drift from the app pages (which are generated from the same list).
 * Base is '/', so paths are absolute.
 */
const tabs = [
  { label: 'Overview', href: '/' },
  ...getMetrics().apps.map((app) => ({ label: app.name, href: `/apps/${app.slug}` })),
];

const current = (Astro.url.pathname.replace(/\/+$/, '') || '/').toLowerCase();

function isActive(href: string): boolean {
  const target = (href.replace(/\/+$/, '') || '/').toLowerCase();
  return current === target;
}
---

<nav class="dash-nav" aria-label="Dashboard sections">
  <div class="container">
    <ul>
      {
        tabs.map((tab) => (
          <li>
            <a href={tab.href} aria-current={isActive(tab.href) ? 'page' : undefined}>
              {tab.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
