---
import { withBase } from '../lib/url';
import { koFiUrl } from '../lib/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-name">CosmoCrew</span>
      <p>Crafted software for focus &amp; learning.</p>
      <a class="footer-support" href={koFiUrl} rel="noopener noreferrer" target="_blank"><span class="heart" aria-hidden="true">&#9829;</span>Support the crew</a>
    </div>

    <nav class="footer-nav" aria-label="Footer">
      <a href={withBase('products')}>Products</a>
      <a href={withBase('about')}>About</a>
      <a href={withBase('support')}>Support</a>
      <a href={withBase('privacy')}>Privacy</a>
      <a
        href="https://github.com/AnunnakiCosmoCrew"
        rel="noopener noreferrer"
        target="_blank">GitHub</a
      >
      <a href="mailto:contact@cosmocrew.dev">Contact</a>
    </nav>
  </div>

  <div class="container footer-base">
    <p>&copy; {year} CosmoCrew. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sp-9);
    border-top: 1px solid var(--c-border);
    padding-block: var(--sp-7) var(--sp-6);
    color: var(--c-ink-soft);
    background-color: var(--c-surface);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-5) var(--sp-7);
    justify-content: space-between;
    align-items: flex-start;
  }

  .footer-name {
    font-weight: 650;
    color: var(--c-ink);
  }

  .footer-brand p {
    margin-top: var(--sp-1);
    font-size: var(--fs-300);
    color: var(--c-muted);
  }

  .footer-support {
    display: inline-flex;
    align-items: center;
    margin-top: var(--sp-4);
    padding: 0.5rem 0.95rem;
    font-size: var(--fs-400);
    font-weight: 600;
    color: var(--c-ink);
    border: 1px solid color-mix(in srgb, var(--c-accent) 45%, var(--c-border));
    border-radius: 999px;
    transition:
      color var(--dur) var(--ease),
      background-color var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .footer-support:hover {
    color: var(--c-accent-contrast);
    background-color: var(--c-accent);
    border-color: var(--c-accent);
  }

  .footer-support .heart {
    color: var(--c-accent);
    margin-right: var(--sp-2);
  }

  .footer-support:hover .heart {
    color: var(--c-accent-contrast);
  }

  @media (prefers-reduced-motion: no-preference) {
    .footer-support:hover {
      transform: translateY(-1px);
    }
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3) var(--sp-5);
  }

  .footer-nav a {
    color: var(--c-ink-soft);
    font-size: var(--fs-400);
  }

  .footer-nav a:hover {
    color: var(--c-ink);
  }

  .footer-base {
    margin-top: var(--sp-6);
    font-size: var(--fs-300);
    color: var(--c-muted);
  }
</style>
