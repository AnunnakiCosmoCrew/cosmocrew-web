---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/url';

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const d = product.data;
const detailHref = withBase(`products/${product.id}`);

const linkDefs = [
  { key: 'website', label: 'Website' },
  { key: 'appStore', label: 'App Store' },
  { key: 'docs', label: 'Docs' },
  { key: 'support', label: 'Support' },
  { key: 'github', label: 'GitHub' },
] as const;

const links = linkDefs
  .map((def) => ({ ...def, href: d.links[def.key] }))
  .filter((l): l is typeof l & { href: string } => Boolean(l.href));
---

<article class="card">
  <div class="card-head">
    <h3 class="card-title">
      <a href={detailHref}>{d.name}</a>
    </h3>
    <span
      class:list={['status', { 'status--live': d.status === 'Live' }]}
      title={`Status: ${d.status}`}
    >
      <span class="status-dot" aria-hidden="true"></span>{d.status}
    </span>
  </div>

  <p class="card-tagline">{d.tagline}</p>

  <p class="card-meta">{d.category} &middot; {d.platform}</p>

  {
    links.length > 0 && (
      <div class="card-links">
        {links.map((l) => (
          <a
            class="chip"
            href={l.href}
            rel="noopener noreferrer"
            target="_blank"
          >
            {l.label}
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    height: 100%;
    padding: var(--sp-5);
    background-color: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }

  .card-title {
    font-size: var(--fs-600);
  }

  .card-title a {
    color: var(--c-ink);
  }

  .card-title a:hover {
    color: var(--c-accent);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-300);
    color: var(--c-muted);
    white-space: nowrap;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--c-muted);
  }

  .status--live .status-dot {
    background-color: var(--c-ok);
  }

  .card-tagline {
    color: var(--c-ink-soft);
  }

  .card-meta {
    font-size: var(--fs-300);
    color: var(--c-muted);
    margin-top: auto;
  }

  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    padding-top: var(--sp-2);
  }

  .chip {
    font-size: var(--fs-300);
    font-weight: 550;
    color: var(--c-ink-soft);
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--c-border);
    border-radius: 999px;
    transition:
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .chip:hover {
    color: var(--c-accent);
    border-color: var(--c-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        transform var(--dur) var(--ease),
        border-color var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }
    .card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-card);
      border-color: color-mix(in srgb, var(--c-accent) 40%, var(--c-border));
    }
  }
</style>
