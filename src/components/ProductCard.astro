---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const d = product.data;

// The whole card links to the app's live website (falls back to the next best
// link if a product has no website).
const primaryHref =
  d.links.website ??
  d.links.appStore ??
  d.links.docs ??
  d.links.support ??
  d.links.github;

// Secondary chips: everything present EXCEPT the website — the card itself is
// the website link, so a separate "Website" chip would be redundant.
const chipDefs = [
  { key: 'appStore', label: 'App Store' },
  { key: 'docs', label: 'Docs' },
  { key: 'support', label: 'Support' },
  { key: 'github', label: 'GitHub' },
] as const;

const chips = chipDefs
  .map((def) => ({ ...def, href: d.links[def.key] }))
  .filter((l): l is typeof l & { href: string } => Boolean(l.href));
---

<article class="card">
  <div class="card-head">
    <div class="card-id">
      <Image
        class="card-icon"
        src={d.icon}
        alt=""
        width={112}
        height={112}
        loading="lazy"
      />
      <h3 class="card-title">
        {
          primaryHref ? (
            <a
              class="card-link"
              href={primaryHref}
              rel="noopener noreferrer"
              target="_blank"
            >
              {d.name}
            </a>
          ) : (
            d.name
          )
        }
      </h3>
    </div>
    <span
      class:list={['status', { 'status--live': d.status === 'Live' }]}
      title={`Status: ${d.status}`}
    >
      <span class="status-dot" aria-hidden="true"></span>{d.status}
    </span>
  </div>

  <p class="card-tagline">{d.tagline}</p>

  <p class="card-meta">{d.category} &middot; {d.platform}</p>

  {
    chips.length > 0 && (
      <div class="card-links">
        {chips.map((l) => (
          <a
            class="chip"
            href={l.href}
            rel="noopener noreferrer"
            target="_blank"
          >
            {l.label}
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .card {
    position: relative; /* anchor for the stretched card link */
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    height: 100%;
    padding: var(--sp-5);
    background-color: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }

  .card-id {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    min-width: 0;
  }

  .card-icon {
    flex: none;
    width: 52px;
    height: 52px;
    border-radius: 22%; /* iOS-style rounding */
    border: 1px solid var(--c-border);
  }

  .card-title {
    font-size: var(--fs-600);
  }

  .card-link {
    color: var(--c-ink);
  }

  /* Stretch the title link over the whole card so clicking anywhere (except the
     chips) opens the website. */
  .card-link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .card:hover .card-link,
  .card-link:hover {
    color: var(--c-accent);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-300);
    color: var(--c-muted);
    white-space: nowrap;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--c-muted);
  }

  .status--live .status-dot {
    background-color: var(--c-ok);
  }

  .card-tagline {
    color: var(--c-ink-soft);
  }

  .card-meta {
    font-size: var(--fs-300);
    color: var(--c-muted);
    margin-top: auto;
  }

  .card-links {
    position: relative; /* sit above the stretched link */
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    padding-top: var(--sp-2);
  }

  .chip {
    font-size: var(--fs-300);
    font-weight: 550;
    color: var(--c-ink-soft);
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--c-border);
    border-radius: 999px;
    transition:
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease);
  }

  .chip:hover {
    color: var(--c-accent);
    border-color: var(--c-accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .card {
      transition:
        transform var(--dur) var(--ease),
        border-color var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }
    .card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-card);
      border-color: color-mix(in srgb, var(--c-accent) 40%, var(--c-border));
    }
  }
</style>
