---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { withBase } from '../lib/url';
---

<BaseLayout
  title="Page not found — CosmoCrew"
  description="The page you were looking for has drifted out of orbit."
  path="404"
>
  <section class="container notfound">
    <p class="eyebrow">404</p>
    <h1>Lost in space</h1>
    <p class="lead">
      The page you were looking for has drifted out of orbit. Let&rsquo;s get
      you back.
    </p>
    <div class="notfound-actions">
      <Button href={withBase('')}>Back home</Button>
      <Button href={withBase('products')} variant="secondary">View products</Button
      >
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    max-width: var(--maxw-prose);
    padding-block: var(--sp-8);
    text-align: center;
  }

  .notfound h1 {
    font-size: var(--fs-800);
    margin-top: var(--sp-2);
  }

  .notfound .lead {
    margin-inline: auto;
    margin-top: var(--sp-4);
  }

  .notfound-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
    margin-top: var(--sp-6);
  }
</style>
