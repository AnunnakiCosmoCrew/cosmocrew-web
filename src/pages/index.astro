---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import ProductCard from '../components/ProductCard.astro';
import { withBase } from '../lib/url';

const featured = (await getCollection('products'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="CosmoCrew — calm, capable apps for focus and learning"
  description="CosmoCrew builds calm, capable apps for focus and learning. SliceFocus and LexiPower are live on iOS, with more on the way."
  path=""
>
  <Hero
    eyebrow="Quietly ambitious"
    title="Calm, capable software, crafted to last."
    lead="CosmoCrew builds apps that do one thing exceptionally well and respect your attention. Two are live today, with more on the way — each made with the same care."
  >
    <Fragment slot="actions">
      <Button href={withBase('products')}>Explore products</Button>
      <Button
        href="https://github.com/AnunnakiCosmoCrew"
        variant="secondary"
        external>View on GitHub</Button
      >
    </Fragment>
  </Hero>

  <section class="container">
    <div class="section-head">
      <p class="eyebrow">Live now</p>
      <h2>Made with care</h2>
    </div>
    <div class="product-grid">
      {featured.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>
