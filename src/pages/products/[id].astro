---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import Prose from '../../components/Prose.astro';
import { withBase } from '../../lib/url';

export const getStaticPaths = (async () => {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}) satisfies GetStaticPaths;

const { product } = Astro.props;
const { Content } = await render(product);
const d = product.data;

const labelMap = {
  appStore: 'App Store',
  website: 'Website',
  docs: 'Docs',
  support: 'Support',
  github: 'GitHub',
} as const;
const primaryLabelMap = {
  appStore: 'Get it on the App Store',
  website: 'Visit website',
  docs: 'Read the docs',
  support: 'Get support',
  github: 'View on GitHub',
} as const;

const order = ['appStore', 'website', 'docs', 'support', 'github'] as const;
const present = order.filter((k) => d.links[k]);
const primaryKey = present[0];
const secondaryKeys = present.slice(1);
---

<BaseLayout
  title={`${d.name} — CosmoCrew`}
  description={d.tagline}
  path={`products/${product.id}`}
>
  <article class="container detail">
    <a class="back" href={withBase('products')}>
      <span aria-hidden="true">&larr;</span> All products
    </a>

    <header class="detail-head">
      <p class="eyebrow">{d.category}</p>
      <h1>{d.name}</h1>
      <p class="lead">{d.tagline}</p>

      <p class="detail-meta">
        <span class:list={['status', { 'status--live': d.status === 'Live' }]}>
          <span class="status-dot" aria-hidden="true"></span>{d.status}
        </span>
        <span class="dot-sep" aria-hidden="true">&middot;</span>
        <span>{d.platform}</span>
      </p>

      {
        present.length > 0 && (
          <div class="detail-actions">
            {primaryKey && (
              <Button href={d.links[primaryKey]!} external>
                {primaryLabelMap[primaryKey]}
              </Button>
            )}
            {secondaryKeys.map((k) => (
              <Button href={d.links[k]!} variant="secondary" external>
                {labelMap[k]}
              </Button>
            ))}
          </div>
        )
      }
    </header>

    <Prose>
      <Content />
    </Prose>
  </article>
</BaseLayout>

<style>
  .detail {
    max-width: var(--maxw-prose);
  }

  .back {
    display: inline-block;
    margin-bottom: var(--sp-6);
    font-size: var(--fs-400);
    color: var(--c-ink-soft);
  }

  .back:hover {
    color: var(--c-accent);
  }

  .detail-head {
    margin-bottom: var(--sp-7);
  }

  .detail-head h1 {
    font-size: var(--fs-800);
    margin-top: var(--sp-2);
  }

  .detail-head .lead {
    margin-top: var(--sp-4);
  }

  .detail-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
    font-size: var(--fs-300);
    color: var(--c-muted);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--c-muted);
  }

  .status--live .status-dot {
    background-color: var(--c-ok);
  }

  .detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
</style>
